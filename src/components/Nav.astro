---
const navLinks = [
  { href: '#about', label: 'About' },
  { href: '#experience', label: 'Experience' },
  { href: '#projects', label: 'Projects' },
  { href: '#skills', label: 'Skills' },
  { href: '#certifications', label: 'Certifications' },
  { href: '#languages', label: 'Languages' },
  { href: '#contact', label: 'Contact' },
];
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-cyan-500/10 bg-arch-950/80 backdrop-blur-md">
  <nav class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4 md:px-8" aria-label="Main navigation">
    <a
      href="#main-content"
      class="group inline-flex items-center transition-transform hover:scale-105"
      aria-label="Hesam Samani — home"
    >
      <span class="site-logo site-logo--cyan site-logo--nav" role="img" aria-hidden="true"></span>
    </a>

    <button
      id="menu-toggle"
      type="button"
      class="flex h-10 w-10 items-center justify-center rounded-sm border border-cyan-500/20 text-arch-200 md:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Toggle navigation menu"
    >
      <svg id="menu-icon-open" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="square" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="menu-icon-close" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="square" d="M6 6l12 12M18 6L6 18" />
      </svg>
    </button>

    <ul class="hidden items-center gap-1 md:flex" role="list">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="rounded-sm px-3 py-2 text-sm font-medium text-arch-200 transition-colors hover:bg-cyan-500/10 hover:text-cyan-300"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-cyan-500/10 bg-arch-950/95 md:hidden" role="dialog" aria-modal="false" aria-label="Mobile navigation">
    <ul class="flex flex-col px-6 py-4" role="list">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="mobile-nav-link block rounded-sm px-3 py-3 text-sm font-medium text-arch-200 transition-colors hover:bg-cyan-500/10 hover:text-cyan-300"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');
  let previousFocus: HTMLElement | null = null;

  function getFocusableElements() {
    if (!menu) return [];
    return Array.from(menu.querySelectorAll<HTMLElement>('a[href], button:not([disabled])'));
  }

  function closeMenu() {
    menu?.classList.add('hidden');
    menu?.setAttribute('aria-modal', 'false');
    toggle?.setAttribute('aria-expanded', 'false');
    iconOpen?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
    previousFocus?.focus();
    previousFocus = null;
  }

  function openMenu() {
    previousFocus = document.activeElement instanceof HTMLElement ? document.activeElement : null;
    menu?.classList.remove('hidden');
    menu?.setAttribute('aria-modal', 'true');
    toggle?.setAttribute('aria-expanded', 'true');
    iconOpen?.classList.add('hidden');
    iconClose?.classList.remove('hidden');
    getFocusableElements()[0]?.focus();
  }

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    if (isOpen) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  document.addEventListener('keydown', (event) => {
    if (menu?.classList.contains('hidden')) return;

    if (event.key === 'Escape') {
      closeMenu();
      toggle?.focus();
      return;
    }

    if (event.key !== 'Tab') return;

    const focusable = [toggle, ...getFocusableElements()].filter(
      (element): element is HTMLElement => element instanceof HTMLElement
    );
    if (focusable.length === 0) return;

    const first = focusable[0];
    const last = focusable[focusable.length - 1];

    if (event.shiftKey && document.activeElement === first) {
      event.preventDefault();
      last.focus();
    } else if (!event.shiftKey && document.activeElement === last) {
      event.preventDefault();
      first.focus();
    }
  });
</script>