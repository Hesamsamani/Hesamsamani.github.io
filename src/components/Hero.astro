---
import { profile } from '../data/profile';

const socialLinks = [
  { href: `mailto:${profile.email}`, label: 'Email', icon: 'mail' },
  { href: profile.whatsapp, label: 'WhatsApp', icon: 'whatsapp' },
  { href: profile.github, label: 'GitHub', icon: 'github' },
  { href: profile.linkedin, label: 'LinkedIn', icon: 'linkedin' },
  { href: profile.codesSite, label: 'Dev Portfolio', icon: 'code' },
];
---

<section class="relative flex min-h-0 items-start overflow-hidden lg:min-h-[92vh] lg:items-center" aria-labelledby="hero-heading" data-hero-section>
  <canvas id="hero-particle-canvas" class="hero-particle-canvas" aria-hidden="true"></canvas>
  <div class="section-container section-container--hero relative z-10 w-full">
    <div class="grid grid-cols-1 items-center gap-8 lg:grid-cols-[1fr_auto] lg:gap-16">
      <div class="reveal reveal-delay-1 mx-auto lg:col-start-2 lg:row-start-1 lg:mx-0">
        <div class="hero-avatar relative mx-auto h-52 w-52 sm:h-56 sm:w-56 md:h-72 md:w-72 lg:mx-0">
          <img
            src="/images/profile.png"
            alt="Hesam Samani — BIM Specialist portrait"
            width="576"
            height="576"
            class="h-full w-full object-cover object-[center_20%]"
            loading="eager"
            fetchpriority="high"
          />
          <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-arch-950/50 via-transparent to-cyan-500/5" aria-hidden="true"></div>
          <div class="pointer-events-none absolute inset-0 ring-1 ring-inset ring-cyan-500/25" aria-hidden="true"></div>
        </div>
      </div>

      <div class="max-w-3xl lg:col-start-1 lg:row-start-1">
        <div class="reveal availability-badge" role="status">
          <span class="availability-badge__dot" aria-hidden="true"></span>
          Open to opportunities
        </div>

        <p class="reveal section-label mb-4">{profile.greeting}</p>

        <h1
          id="hero-heading"
          class="reveal reveal-delay-1 font-display text-5xl font-bold leading-[1.05] tracking-tight text-arch-50 md:text-7xl"
        >
          {profile.name}
        </h1>

        <p class="reveal reveal-delay-2 age-note mt-3" aria-label={`${profile.age} years old`}>
          <svg class="age-note__icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
            <path stroke-linecap="square" d="M8 7V3a4 4 0 118 0v4M6 11h12v10H6V11z" />
            <path stroke-linecap="square" d="M6 7h12" />
          </svg>
          <span class="age-note__value">{profile.age}</span>
          <span class="age-note__text">years old</span>
        </p>

        <div class="reveal reveal-delay-2 hero-tags mt-5" role="list" aria-label="Professional focus areas">
          {
            profile.roleTags.map((tag) => (
              <span class="hero-role-tag" role="listitem">{tag}</span>
            ))
          }
          {
            profile.secondaryTags.map((tag) => (
              <span class="hero-role-tag hero-role-tag--accent" role="listitem">{tag}</span>
            ))
          }
        </div>

        <p class="reveal reveal-delay-2 mt-5 max-w-2xl text-lg font-light leading-relaxed text-arch-200 md:text-xl">
          {profile.tagline}
        </p>

        <div class="reveal reveal-delay-3 mt-6 flex flex-wrap items-center gap-x-3 gap-y-1.5 text-sm text-arch-200">
          <span class="flex items-center gap-2">
            <svg class="h-4 w-4 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="square" d="M12 11.5a2.5 2.5 0 100-5 2.5 2.5 0 000 5z" />
              <path stroke-linecap="square" d="M12 21s7-4.5 7-10a7 7 0 10-14 0c0 5.5 7 10 7 10z" />
            </svg>
            {profile.location}
          </span>
          <span class="hidden text-cyan-500/40 sm:inline" aria-hidden="true">&middot;</span>
          <span class="text-cyan-400/80">{profile.relocation}</span>
        </div>

        <div class="reveal reveal-delay-4 mt-10 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:gap-4">
          <a href="#contact" data-magnetic class="btn-primary">
            Get in Touch
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="square" d="M5 12h14M13 6l6 6-6 6" />
            </svg>
          </a>
          <div class="grid grid-cols-2 gap-3 sm:contents">
            <a href="#projects" class="btn-secondary">
              View Projects
            </a>
            <a href="#experience" class="btn-ghost">
              Experience
            </a>
          </div>
        </div>

        <div class="reveal reveal-delay-5 mt-8 flex flex-wrap items-center gap-3" role="list" aria-label="Social links">
          {
            socialLinks.map((link) => (
              <a
                href={link.href}
                target={link.href.startsWith('mailto') ? undefined : '_blank'}
                rel={link.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
                class="social-chip group"
                aria-label={link.label}
                role="listitem"
              >
                {link.icon === 'github' && (
                  <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
                  </svg>
                )}
                {link.icon === 'linkedin' && (
                  <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 114.126 0 2.063 2.063 0 01-2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                  </svg>
                )}
                {link.icon === 'code' && (
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="square" d="M10 8l-6 6 6 6M14 16l6-6-6-6" />
                  </svg>
                )}
                {link.icon === 'mail' && (
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="square" d="M3 8l9 6 9-6M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                )}
                {link.icon === 'whatsapp' && (
                  <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                  </svg>
                )}
                <span class="text-xs font-medium">{link.label}</span>
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <div class="reveal reveal-delay-5 mt-16 glass-stats-panel">
      <div class="glass-stats-panel__glow" aria-hidden="true"></div>
      <div class="relative z-10 grid grid-cols-3">
        {
          profile.stats.map((stat) => (
            <div class="stat-card">
              <p class="font-display text-2xl font-bold text-cyan-400 md:text-4xl" data-count={stat.value}>
                {stat.value}
              </p>
              <p class="mt-1 text-[10px] font-medium uppercase tracking-wider text-arch-300 md:text-xs">{stat.label}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2" aria-hidden="true">
    <div class="flex flex-col items-center gap-2 text-cyan-500/40">
      <span class="text-[10px] uppercase tracking-[0.3em]">Scroll</span>
      <svg class="h-5 w-5 motion-reduce:animate-none animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="square" d="M12 5v14M6 13l6 6 6-6" />
      </svg>
    </div>
  </div>
</section>

<script>
  const animateCounters = () => {
    document.querySelectorAll<HTMLElement>('[data-count]').forEach((el) => {
      const raw = el.dataset.count ?? '';
      const match = raw.match(/^(\d+)(.*)$/);
      if (!match) return;

      const target = Number(match[1]);
      const suffix = match[2] ?? '';
      const duration = 1200;
      const start = performance.now();

      const tick = (now: number) => {
        const progress = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = `${Math.round(target * eased)}${suffix}`;
        if (progress < 1) requestAnimationFrame(tick);
      };

      requestAnimationFrame(tick);
    });
  };

  const heroStats = document.querySelector('.stat-card')?.closest('section');
  if (heroStats) {
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries.some((entry) => entry.isIntersecting)) {
          animateCounters();
          observer.disconnect();
        }
      },
      { threshold: 0.4 }
    );
    observer.observe(heroStats);
  }
</script>