---
import { profile } from '../data/profile';
---

<section class="relative flex min-h-[90vh] items-center pt-20" aria-labelledby="hero-heading">
  <div class="section-container w-full">
    <div class="grid items-center gap-12 lg:grid-cols-[1fr_auto] lg:gap-16">
      <div class="max-w-3xl">
        <p class="reveal section-label mb-4">BIM Professional</p>

        <h1 id="hero-heading" class="reveal reveal-delay-1 font-display text-5xl font-bold leading-[1.1] tracking-tight text-charcoal-50 md:text-7xl">
          {profile.name}
        </h1>

        <div class="reveal reveal-delay-2 mt-6 flex flex-wrap gap-2">
          {
            profile.roleTags.map((tag) => (
              <span class="inline-flex items-center rounded-sm border border-copper-500/30 bg-copper-500/10 px-3 py-1.5 text-sm font-medium text-copper-300">
                {tag}
              </span>
            ))
          }
        </div>

        <p class="reveal reveal-delay-2 mt-5 text-lg font-light text-charcoal-400 md:text-xl">
          {profile.tagline}
        </p>

        <div class="reveal reveal-delay-3 mt-6 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-charcoal-400">
          <span class="flex items-center gap-2">
            <svg class="h-4 w-4 text-copper-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="square" d="M12 11.5a2.5 2.5 0 100-5 2.5 2.5 0 000 5z" />
              <path stroke-linecap="square" d="M12 21s7-4.5 7-10a7 7 0 10-14 0c0 5.5 7 10 7 10z" />
            </svg>
            {profile.location}
          </span>
          <span class="hidden text-copper-500/40 sm:inline" aria-hidden="true">&middot;</span>
          <span class="text-copper-400/80">{profile.relocation}</span>
        </div>

        <div class="reveal reveal-delay-4 mt-10 flex flex-wrap gap-4">
          <a
            href="#contact"
            class="inline-flex items-center gap-2 rounded-sm bg-copper-500 px-6 py-3 text-sm font-semibold text-charcoal-950 transition-all hover:bg-copper-400 hover:shadow-lg hover:shadow-copper-500/20"
          >
            Get in Touch
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="square" d="M5 12h14M13 6l6 6-6 6" />
            </svg>
          </a>
          <a
            href="#experience"
            class="inline-flex items-center gap-2 rounded-sm border border-copper-500/30 px-6 py-3 text-sm font-semibold text-copper-300 transition-all hover:border-copper-400 hover:bg-copper-500/10"
          >
            View Experience
          </a>
        </div>
      </div>

      <div class="reveal reveal-delay-3 mx-auto lg:mx-0">
        <div
          class="hero-avatar relative flex h-56 w-56 items-center justify-center overflow-hidden rounded-sm border border-copper-500/25 md:h-64 md:w-64"
          role="img"
          aria-label="Professional portrait placeholder"
        >
          <div class="absolute inset-0 bg-gradient-to-br from-copper-600/30 via-charcoal-800 to-charcoal-950" aria-hidden="true"></div>
          <div class="absolute inset-0 opacity-20" aria-hidden="true">
            <svg class="h-full w-full" viewBox="0 0 256 256" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M0 0h256v256" stroke="rgba(184,115,51,0.4)" stroke-width="1" />
              <path d="M0 64h256M0 128h256M0 192h256" stroke="rgba(184,115,51,0.15)" stroke-width="1" />
              <path d="M64 0v256M128 0v256M192 0v256" stroke="rgba(184,115,51,0.15)" stroke-width="1" />
            </svg>
          </div>
          <svg
            class="relative h-36 w-36 text-copper-500/50 md:h-44 md:w-44"
            viewBox="0 0 120 120"
            fill="currentColor"
            aria-hidden="true"
          >
            <circle cx="60" cy="38" r="22" opacity="0.6" />
            <path d="M20 108c0-22 18-40 40-40s40 18 40 40" opacity="0.45" />
          </svg>
          <div class="absolute bottom-0 left-0 right-0 h-1/3 bg-gradient-to-t from-charcoal-950/80 to-transparent" aria-hidden="true"></div>
        </div>
      </div>
    </div>

    <div class="reveal reveal-delay-5 mt-16 grid grid-cols-3 gap-4 md:gap-8">
      {
        profile.stats.map((stat) => (
          <div class="blueprint-card p-4 text-center md:p-6">
            <p class="font-display text-2xl font-bold text-copper-400 md:text-3xl">{stat.value}</p>
            <p class="mt-1 text-xs font-medium uppercase tracking-wider text-charcoal-400 md:text-sm">{stat.label}</p>
          </div>
        ))
      }
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2" aria-hidden="true">
    <div class="flex flex-col items-center gap-2 text-copper-500/40">
      <span class="text-[10px] uppercase tracking-[0.3em]">Scroll</span>
      <svg class="h-5 w-5 motion-reduce:animate-none animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="square" d="M12 5v14M6 13l6 6 6-6" />
      </svg>
    </div>
  </div>
</section>