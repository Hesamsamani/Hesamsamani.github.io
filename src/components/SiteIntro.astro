---
import { profile } from '../data/profile';
---

<div
  id="site-intro"
  class="site-intro fixed inset-0 z-[200] flex items-center justify-center bg-arch-950"
  role="dialog"
  aria-modal="true"
  aria-labelledby="intro-title"
  aria-describedby="intro-desc"
>
  <div id="intro-particles" class="intro-particles" aria-hidden="true"></div>
  <div class="absolute inset-0 opacity-40" aria-hidden="true">
    <div class="h-full w-full bg-[radial-gradient(ellipse_at_center,rgba(33,129,189,0.15),transparent_70%)]"></div>
  </div>

  <div class="relative mx-auto w-full max-w-lg px-8 text-center">
    <span class="site-logo site-logo--cyan site-logo--intro mx-auto block" role="img" aria-label="Hesam Samani logo"></span>

    <div class="intro-profile mx-auto mt-6 h-52 w-52 sm:h-56 sm:w-56 md:h-64 md:w-64">
      <img
        src="/images/profile.png"
        alt=""
        width="256"
        height="256"
        class="h-full w-full object-cover object-[center_20%]"
        loading="eager"
      />
    </div>
    <h1 id="intro-title" class="mt-8 font-display text-3xl font-semibold text-arch-50">
      Hesam Samani
    </h1>
    <p id="intro-desc" class="intro-tagline mt-3 text-base text-arch-200">
      BIM Specialist · MEP &amp; HVAC Engineer
      <span class="text-arch-500" aria-label={`${profile.age} years old`}> · {profile.age}</span>
    </p>

    <div class="intro-progress-track mx-auto mt-8 h-1 max-w-xs overflow-hidden rounded-full bg-arch-800">
      <div id="intro-progress-bar" class="intro-progress-bar h-full w-0 rounded-full bg-cyan-500"></div>
    </div>

    <p class="intro-loading-label mt-4 font-mono text-xs uppercase tracking-[0.35em] text-cyan-500/80" aria-live="polite">
      Loading experience...
    </p>

    <button
      type="button"
      id="enter-site"
      class="intro-enter-btn mt-10 inline-flex items-center gap-2 rounded-sm bg-cyan-500 px-8 py-3.5 text-sm font-semibold text-white opacity-0 pointer-events-none transition-all hover:bg-cyan-400 hover:shadow-lg hover:shadow-cyan-500/25"
      aria-hidden="true"
      tabindex="-1"
    >
      Continue
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="square" d="M5 12h14M13 6l6 6-6 6" />
      </svg>
    </button>
  </div>
</div>

<script>
  const intro = document.getElementById('site-intro');
  const enterBtn = document.getElementById('enter-site');
  const bar = document.getElementById('intro-progress-bar');
  const particleRoot = document.getElementById('intro-particles');

  if (particleRoot) {
    const count = window.innerWidth <= 768 ? 28 : 55;
    for (let i = 0; i < count; i++) {
      const p = document.createElement('span');
      p.className = 'intro-particle';
      p.style.left = `${Math.random() * 100}%`;
      p.style.top = `${Math.random() * 100}%`;
      p.style.animationDelay = `${Math.random() * 4}s`;
      p.style.animationDuration = `${3 + Math.random() * 3}s`;
      particleRoot.appendChild(p);
    }
  }

  const showContinue = () => {
    if (!enterBtn) return;
    enterBtn.classList.remove('opacity-0', 'pointer-events-none');
    enterBtn.classList.add('intro-enter-btn--visible');
    enterBtn.removeAttribute('aria-hidden');
    enterBtn.removeAttribute('tabindex');
    enterBtn.focus();
  };

  if (intro) {
    document.body.style.overflow = 'hidden';
  }

  let progress = 0;
  const tick = window.setInterval(() => {
    if (!bar) return;
    progress += Math.random() * 12 + 4;
    if (progress >= 100) {
      progress = 100;
      bar.style.width = '100%';
      window.clearInterval(tick);
      window.setTimeout(showContinue, 280);
    } else {
      bar.style.width = `${progress}%`;
    }
  }, 110);

  const dismissIntro = () => {
    if (!intro) return;
    intro.classList.add('site-intro--exit');
    window.setTimeout(() => intro.remove(), 500);
    document.body.style.overflow = '';
    window.dispatchEvent(new CustomEvent('hesam:intro-dismissed'));
    if (typeof window.startPortfolioMusic === 'function') {
      window.startPortfolioMusic();
    }
  };

  enterBtn?.addEventListener('click', dismissIntro);

  document.addEventListener('keydown', (event) => {
    if (
      event.key === 'Enter' &&
      intro &&
      document.body.contains(intro) &&
      enterBtn &&
      !enterBtn.classList.contains('pointer-events-none')
    ) {
      dismissIntro();
    }
  });
</script>