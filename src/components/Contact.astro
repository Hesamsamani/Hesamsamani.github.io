---
import { profile } from '../data/profile';

const linkedinHandle = profile.linkedin.replace(/\/$/, '').split('/').pop() ?? 'linkedin';
---

<section id="contact" class="relative" aria-labelledby="contact-heading">
  <div class="blueprint-divider" aria-hidden="true"></div>
  <div class="section-container">
    <div class="reveal mb-12">
      <p class="section-label mb-2">Connect</p>
      <h2 id="contact-heading" class="section-title">Contact</h2>
      <p class="mt-4 max-w-xl text-base text-arch-200">
        Open to BIM specialist and Revit professional roles in healthcare and commercial AEC. Let's connect.
      </p>
    </div>

    <div class="reveal reveal-delay-1 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <a
        href={`mailto:${profile.email}`}
        class="contact-card group"
      >
        <svg class="h-6 w-6 text-cyan-500 transition-colors group-hover:text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="square" d="M3 8l9 6 9-6M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-arch-500">Email</p>
          <p class="contact-card__value">{profile.email}</p>
        </div>
      </a>

      <a
        href={profile.whatsapp}
        target="_blank"
        rel="noopener noreferrer"
        class="contact-card group"
      >
        <svg class="h-6 w-6 text-cyan-500 transition-colors group-hover:text-cyan-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
        </svg>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-arch-500">WhatsApp</p>
          <p class="contact-card__value">Message me</p>
        </div>
      </a>

      <a
        href={`tel:${profile.phone.replace(/\s/g, '')}`}
        class="contact-card group"
      >
        <svg class="h-6 w-6 text-cyan-500 transition-colors group-hover:text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="square" d="M6.5 4h3l2 5-2.5 1.5a11 11 0 005 5L15.5 13l5 2v3a1 1 0 01-1 1A15 15 0 014 5.5a1 1 0 011-1.5z" />
        </svg>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-arch-500">Phone</p>
          <p class="contact-card__value">{profile.phone}</p>
        </div>
      </a>

      <a
        href={profile.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="contact-card group"
      >
        <svg class="h-6 w-6 text-cyan-500 transition-colors group-hover:text-cyan-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 114.126 0 2.063 2.063 0 01-2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
        </svg>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-arch-500">LinkedIn</p>
          <p class="contact-card__value">{linkedinHandle}</p>
        </div>
      </a>

      <a
        href={profile.github}
        target="_blank"
        rel="noopener noreferrer"
        class="contact-card group"
      >
        <svg class="h-6 w-6 text-cyan-500 transition-colors group-hover:text-cyan-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
        </svg>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-arch-500">GitHub</p>
          <p class="contact-card__value">Hesamsamani</p>
        </div>
      </a>
    </div>
  </div>
</section>