---
import { profile } from '../data/profile';
---

<section id="contact" class="relative" aria-labelledby="contact-heading">
  <div class="blueprint-divider" aria-hidden="true"></div>
  <div class="section-container">
    <div class="reveal mb-12">
      <p class="section-label mb-2">Connect</p>
      <h2 id="contact-heading" class="section-title">Contact</h2>
      <p class="mt-4 max-w-xl text-base text-charcoal-400">
        Open to BIM specialist and Revit professional roles in healthcare and commercial AEC. Let's connect.
      </p>
    </div>

    <div class="reveal reveal-delay-1 grid gap-4 sm:grid-cols-3">
      <a
        href={`mailto:${profile.email}`}
        class="blueprint-card group flex flex-col gap-3 p-6 transition-all hover:border-copper-400/40 hover:bg-charcoal-800/40"
      >
        <svg class="h-6 w-6 text-copper-500 transition-colors group-hover:text-copper-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="square" d="M3 8l9 6 9-6M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-charcoal-500">Email</p>
          <p class="mt-1 text-sm font-medium text-charcoal-200 group-hover:text-copper-300">{profile.email}</p>
        </div>
      </a>

      <a
        href={`tel:${profile.phone.replace(/\s/g, '')}`}
        class="blueprint-card group flex flex-col gap-3 p-6 transition-all hover:border-copper-400/40 hover:bg-charcoal-800/40"
      >
        <svg class="h-6 w-6 text-copper-500 transition-colors group-hover:text-copper-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="square" d="M6.5 4h3l2 5-2.5 1.5a11 11 0 005 5L15.5 13l5 2v3a1 1 0 01-1 1A15 15 0 014 5.5a1 1 0 011-1.5z" />
        </svg>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-charcoal-500">Phone</p>
          <p class="mt-1 text-sm font-medium text-charcoal-200 group-hover:text-copper-300">{profile.phone}</p>
        </div>
      </a>

      <a
        href={profile.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="blueprint-card group flex flex-col gap-3 p-6 transition-all hover:border-copper-400/40 hover:bg-charcoal-800/40"
      >
        <svg class="h-6 w-6 text-copper-500 transition-colors group-hover:text-copper-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 114.126 0 2.063 2.063 0 01-2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
        </svg>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-charcoal-500">LinkedIn</p>
          <p class="mt-1 text-sm font-medium text-charcoal-200 group-hover:text-copper-300">hesam-samani</p>
        </div>
      </a>
    </div>
  </div>
</section>