---
import { profile } from '../data/profile';

const categoryIcons: Record<string, string> = {
  'BIM Authoring': 'building',
  'Coordination & QA': 'layers',
  'Standards & Delivery': 'document',
  Software: 'monitor',
};
---

<section id="skills" class="relative" aria-labelledby="skills-heading">
  <div class="blueprint-divider" aria-hidden="true"></div>
  <div class="section-container">
    <div class="reveal mb-12">
      <p class="section-label mb-2">Toolkit</p>
      <h2 id="skills-heading" class="section-title">Technical Skills</h2>
      <p class="mt-4 max-w-2xl text-base text-arch-200">
        Core competencies across BIM authoring, coordination, standards, and supporting software.
      </p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        profile.skills.map((group, index) => (
          <div class={`reveal reveal-delay-${index + 1} skill-card group`}>
            <span class="skill-card__corner skill-card__corner--tl" aria-hidden="true"></span>
            <span class="skill-card__corner skill-card__corner--tr" aria-hidden="true"></span>
            <span class="skill-card__corner skill-card__corner--bl" aria-hidden="true"></span>
            <span class="skill-card__corner skill-card__corner--br" aria-hidden="true"></span>
            <div class="skill-card__icon" aria-hidden="true">
              {categoryIcons[group.category] === 'building' && (
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                  <path stroke-linecap="square" d="M4 20V9l8-5 8 5v11" />
                  <path stroke-linecap="square" d="M9 20v-6h6v6" />
                </svg>
              )}
              {categoryIcons[group.category] === 'layers' && (
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                  <path stroke-linecap="square" d="M12 3L3 8l9 5 9-5-9-5z" />
                  <path stroke-linecap="square" d="M3 12l9 5 9-5" />
                  <path stroke-linecap="square" d="M3 16l9 5 9-5" />
                </svg>
              )}
              {categoryIcons[group.category] === 'document' && (
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                  <path stroke-linecap="square" d="M7 3h7l5 5v13a1 1 0 01-1 1H7a1 1 0 01-1-1V4a1 1 0 011-1z" />
                  <path stroke-linecap="square" d="M14 3v5h5" />
                  <path stroke-linecap="round" d="M8 12h8M8 16h5" />
                </svg>
              )}
              {categoryIcons[group.category] === 'monitor' && (
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                  <rect x="3" y="4" width="18" height="12" rx="1.5" />
                  <path stroke-linecap="square" d="M8 20h8M12 16v4" />
                </svg>
              )}
              {!categoryIcons[group.category] && (
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                  <path stroke-linecap="square" d="M4 7h16M4 12h10M4 17h16" />
                </svg>
              )}
            </div>
            <div class="mb-4 flex items-center justify-between gap-2">
              <h3 class="text-xs font-semibold uppercase tracking-[0.15em] text-cyan-400">
                {group.category}
              </h3>
              <span class="rounded-sm bg-arch-800/80 px-2 py-0.5 font-mono text-[10px] text-arch-200">
                {group.items.length} tools
              </span>
            </div>
            <ul class="flex flex-wrap gap-2" role="list">
              {group.items.map((skill) => (
                <li>
                  <span class="skill-pill inline-block cursor-default rounded-sm border border-cyan-500/20 bg-arch-800/50 px-3 py-1.5 text-sm text-arch-200 transition-colors duration-200 hover:border-cyan-500/40 hover:text-cyan-300">
                    {skill}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>