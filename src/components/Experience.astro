---
import { profile } from '../data/profile';
---

<section id="experience" class="relative" aria-labelledby="experience-heading">
  <div class="blueprint-divider" aria-hidden="true"></div>
  <div class="section-container">
    <div class="reveal mb-12">
      <p class="section-label mb-2">Career</p>
      <h2 id="experience-heading" class="section-title">Experience & Education</h2>
      <p class="mt-4 max-w-2xl text-base text-arch-200">
        Healthcare BIM delivery, academic instruction, and multidisciplinary coordination across Iran and Belgium.
      </p>
    </div>

    <ol class="relative space-y-8" role="list">
      {
        profile.experience.map((job, index) => (
          <li class={`reveal reveal-delay-${Math.min(index + 1, 5)}`}>
            <article
              class:list={[
                'blueprint-card relative overflow-hidden p-6 md:p-8',
                job.featured && 'ring-1 ring-cyan-500/25',
              ]}
            >
              <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                <div class="flex min-w-0 gap-4">
                  <div
                    class="flex h-12 w-12 shrink-0 items-center justify-center rounded-sm border border-cyan-500/25 bg-arch-800/80 font-display text-lg font-bold text-cyan-400"
                    aria-hidden="true"
                  >
                    {job.company.charAt(0)}
                  </div>
                  <div class="min-w-0">
                    <div class="flex flex-wrap items-center gap-2">
                      <h3 class="font-display text-xl font-semibold text-arch-50">{job.role}</h3>
                      {job.featured && (
                        <span class="experience-featured-badge">Featured Role</span>
                      )}
                    </div>
                    <p class="text-cyan-400">{job.company}</p>
                  </div>
                </div>
                <div class="experience-card__meta sm:pl-4">
                  {'duration' in job && job.duration && (
                    <span class="rounded-sm border border-cyan-500/20 bg-arch-800/60 px-2.5 py-1 font-mono text-xs text-cyan-300">
                      {job.duration}
                    </span>
                  )}
                  <time class="font-mono text-sm text-arch-500">{job.period}</time>
                </div>
              </div>

              <ul class="mt-5 space-y-2" role="list">
                {job.bullets.map((bullet) => (
                  <li class="flex items-start gap-3 text-sm leading-relaxed text-arch-200 md:text-base">
                    <span class="mt-2 h-1 w-1 shrink-0 bg-cyan-400" aria-hidden="true" />
                    {bullet}
                  </li>
                ))}
              </ul>

              {'tags' in job && job.tags && (
                <div class="mt-6 flex flex-wrap gap-2 border-t border-cyan-500/10 pt-5">
                  {job.tags.map((tag) => (
                    <span class="rounded-sm border border-cyan-500/20 bg-cyan-500/5 px-2.5 py-1 font-mono text-xs text-cyan-300">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </article>
          </li>
        ))
      }
    </ol>
  </div>
</section>