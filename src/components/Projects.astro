---
import { profile } from '../data/profile';
---

<section id="projects" class="relative" aria-labelledby="projects-heading">
  <div class="blueprint-divider" aria-hidden="true"></div>
  <div class="section-container">
    <div class="reveal mb-12">
      <p class="section-label mb-2">Selected Work</p>
      <h2 id="projects-heading" class="section-title">Projects</h2>
      <p class="mt-4 max-w-2xl text-base text-charcoal-400">
        Anonymized case studies highlighting healthcare delivery, workflow optimization, and BIM education outcomes.
      </p>
    </div>

    <div class="grid gap-6 lg:grid-cols-3">
      {
        profile.projects.map((project, index) => (
          <article
            class={`reveal reveal-delay-${Math.min(index + 1, 5)} blueprint-card flex flex-col overflow-hidden`}
          >
            <div
              class="relative flex h-36 items-end overflow-hidden border-b border-copper-500/15 bg-gradient-to-br from-charcoal-800 via-charcoal-900 to-charcoal-950 p-5"
              aria-hidden="true"
            >
              <div class="absolute inset-0 opacity-30">
                <svg class="h-full w-full" viewBox="0 0 320 144" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M0 120h80v24H0zM96 96h64v48H96zM176 72h96v72H176z" fill="rgba(184,115,51,0.15)" />
                  <path d="M0 0h320v144" stroke="rgba(184,115,51,0.2)" stroke-width="1" />
                  <path d="M0 36h320M0 72h320M0 108h320" stroke="rgba(184,115,51,0.08)" stroke-width="1" />
                  <path d="M40 0v144M120 0v144M200 0v144M280 0v144" stroke="rgba(184,115,51,0.08)" stroke-width="1" />
                </svg>
              </div>
              <span class="relative text-xs font-semibold uppercase tracking-[0.15em] text-copper-400">
                {project.category}
              </span>
            </div>

            <div class="flex flex-1 flex-col p-6">
              <h3 class="font-display text-xl font-semibold text-charcoal-50">{project.title}</h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-charcoal-300">{project.description}</p>

              <ul class="mt-5 space-y-2" role="list">
                {project.highlights.map((highlight) => (
                  <li class="flex items-start gap-2.5 text-sm text-charcoal-400">
                    <span class="mt-2 h-1 w-1 shrink-0 bg-copper-400" aria-hidden="true" />
                    {highlight}
                  </li>
                ))}
              </ul>

              <div class="mt-6 flex flex-wrap gap-2 border-t border-copper-500/10 pt-5">
                {project.metrics.map((metric) => (
                  <span class="rounded-sm border border-copper-500/25 bg-copper-500/5 px-2.5 py-1 font-mono text-xs text-copper-300">
                    {metric}
                  </span>
                ))}
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>