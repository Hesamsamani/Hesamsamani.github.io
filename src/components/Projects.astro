---
import { profile } from '../data/profile';

const categories = ['All', ...new Set(profile.projects.map((p) => p.category))];
---

<section id="projects" class="relative" aria-labelledby="projects-heading">
  <div class="blueprint-divider" aria-hidden="true"></div>
  <div class="section-container">
    <div class="reveal mb-12">
      <p class="section-label mb-2">Selected Work</p>
      <h2 id="projects-heading" class="section-title">Projects</h2>
      <p class="mt-4 max-w-2xl text-base text-arch-200">
        Anonymized case studies highlighting healthcare delivery, workflow optimization, and BIM education outcomes.
      </p>
    </div>

    <div
      class="reveal reveal-delay-1 mb-10 flex flex-wrap gap-2"
      role="group"
      aria-label="Filter projects by category"
      data-project-filters
    >
      {
        categories.map((category, index) => (
          <button
            type="button"
            class:list={[
              'rounded-sm border px-4 py-2 text-xs font-semibold uppercase tracking-wider transition-all',
              index === 0
                ? 'border-cyan-500/50 bg-cyan-500/15 text-cyan-300'
                : 'border-cyan-500/20 bg-arch-900/40 text-arch-200 hover:border-cyan-400/40 hover:text-cyan-300',
            ]}
            data-filter={category}
            aria-pressed={index === 0 ? 'true' : 'false'}
          >
            {category}
          </button>
        ))
      }
    </div>

    <p class="sr-only" aria-live="polite" aria-atomic="true" data-project-filter-status>
      Showing {profile.projects.length} projects
    </p>

    <div class="grid gap-6 lg:grid-cols-3" data-project-grid>
      {
        profile.projects.map((project, index) => (
          <article
            class={`reveal reveal-delay-${Math.min(index + 1, 5)} project-card group transition-opacity`}
            data-project-card
            data-category={project.category}
          >
            <span class="project-card__corner project-card__corner--tl" aria-hidden="true"></span>
            <span class="project-card__corner project-card__corner--tr" aria-hidden="true"></span>
            <span class="project-card__corner project-card__corner--bl" aria-hidden="true"></span>
            <span class="project-card__corner project-card__corner--br" aria-hidden="true"></span>
            <div class="project-card__media" aria-hidden="true">
              <div class="absolute inset-0 opacity-30">
                <svg class="h-full w-full" viewBox="0 0 320 144" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M0 120h80v24H0zM96 96h64v48H96zM176 72h96v72H176z" fill="rgba(33,129,189,0.15)" />
                  <path d="M0 0h320v144" stroke="rgba(33,129,189,0.2)" stroke-width="1" />
                  <path d="M0 36h320M0 72h320M0 108h320" stroke="rgba(33,129,189,0.08)" stroke-width="1" />
                  <path d="M40 0v144M120 0v144M200 0v144M280 0v144" stroke="rgba(33,129,189,0.08)" stroke-width="1" />
                </svg>
              </div>
              <span class="relative text-xs font-semibold uppercase tracking-[0.15em] text-cyan-400">
                {project.category}
              </span>
            </div>

            <div class="flex flex-1 flex-col p-6">
              <h3 class="font-display text-xl font-semibold text-arch-50">{project.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-arch-200">{project.description}</p>

              <details class="project-details mt-4 group/details">
                <summary class="flex cursor-pointer list-none items-center gap-2 text-sm font-medium text-cyan-400 transition-colors duration-200 hover:text-cyan-300">
                  <svg class="h-3.5 w-3.5 shrink-0 transition-transform duration-200 group-open/details:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path stroke-linecap="square" d="M9 6l6 6-6 6" />
                  </svg>
                  View highlights
                </summary>
                <ul class="mt-3 space-y-2 border-l border-cyan-500/20 pl-4" role="list">
                  {project.highlights.map((highlight) => (
                    <li class="text-sm leading-relaxed text-arch-200">{highlight}</li>
                  ))}
                </ul>
              </details>

              <div class="flex-1" aria-hidden="true"></div>

              <div class="mt-6 flex flex-wrap gap-2 border-t border-cyan-500/10 pt-5">
                {project.metrics.map((metric) => (
                  <span class="rounded-sm border border-cyan-500/25 bg-cyan-500/5 px-2.5 py-1 font-mono text-xs text-cyan-300">
                    {metric}
                  </span>
                ))}
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<script>
  const filterRoot = document.querySelector('[data-project-filters]');
  const grid = document.querySelector('[data-project-grid]');
  const filterStatus = document.querySelector('[data-project-filter-status]');

  if (filterRoot && grid) {
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('[data-project-card]'));
    const buttons = Array.from(filterRoot.querySelectorAll<HTMLButtonElement>('[data-filter]'));

    const setActiveButton = (active: HTMLButtonElement) => {
      buttons.forEach((button) => {
        const isActive = button === active;
        button.setAttribute('aria-pressed', String(isActive));
        button.classList.toggle('border-cyan-500/50', isActive);
        button.classList.toggle('bg-cyan-500/15', isActive);
        button.classList.toggle('text-cyan-300', isActive);
        button.classList.toggle('border-cyan-500/20', !isActive);
        button.classList.toggle('bg-arch-900/40', !isActive);
        button.classList.toggle('text-arch-200', !isActive);
      });
    };

    const applyFilter = (filter: string) => {
      let visibleCount = 0;

      cards.forEach((card) => {
        const category = card.dataset.category ?? '';
        const isVisible = filter === 'All' || category === filter;
        card.classList.toggle('hidden', !isVisible);
        if (isVisible) visibleCount += 1;
      });

      if (filterStatus) {
        filterStatus.textContent =
          visibleCount === 1 ? 'Showing 1 project' : `Showing ${visibleCount} projects`;
      }
    };

    filterRoot.addEventListener('click', (event) => {
      const target = (event.target as HTMLElement).closest<HTMLButtonElement>('[data-filter]');
      if (!target) return;
      setActiveButton(target);
      applyFilter(target.dataset.filter ?? 'All');
    });
  }
</script>