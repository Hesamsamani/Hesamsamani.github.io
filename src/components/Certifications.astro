---
import { profile } from '../data/profile';
---

<section id="certifications" class="relative" aria-labelledby="certifications-heading">
  <div class="blueprint-divider" aria-hidden="true"></div>
  <div class="section-container">
    <div class="reveal mb-12">
      <p class="section-label mb-2">Credentials</p>
      <h2 id="certifications-heading" class="section-title">Certifications</h2>
    </div>

    <ul class="grid gap-4 sm:grid-cols-2" role="list">
      {
        profile.certifications.map((cert, index) => (
          <li class={`reveal reveal-delay-${Math.min(index + 1, 5)} blueprint-card flex items-start gap-4 p-5`}>
            <div
              class="flex h-10 w-10 shrink-0 items-center justify-center rounded-sm border border-copper-500/30 bg-copper-500/10"
              aria-hidden="true"
            >
              <svg class="h-5 w-5 text-copper-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="square" d="M9 12l2 2 4-4" />
                <path stroke-linecap="square" d="M12 3l7 4v5c0 4-3 7-7 9-4-2-7-5-7-9V7l7-4z" />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-charcoal-100">{cert.name}</p>
              <p class="mt-0.5 text-sm text-charcoal-500">{cert.issuer}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>