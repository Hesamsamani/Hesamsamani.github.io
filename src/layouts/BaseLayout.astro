---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import InteractiveLayer from '../components/InteractiveLayer.astro';

interface Props {
  title?: string;
  description?: string;
}

const siteUrl = Astro.site?.href.replace(/\/$/, '') ?? 'https://hesamsamani.me';
const ogImage = `${siteUrl}/og.png`;

const {
  title = 'Hesam Samani — BIM Specialist',
  description = 'BIM Specialist with 4+ years delivering healthcare and commercial projects in Revit. Autodesk ACP certified (Architecture, Structure, MEP). Based in Hasselt, Belgium — open to relocation.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Hesam Samani" />
    <link rel="canonical" href={`${siteUrl}/`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:type" content="profile" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="Hesam Samani — BIM Specialist portfolio" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Hesam Samani — BIM Specialist portfolio" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#f8fcff" />
    <title>{title}</title>
  </head>
  <body>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-sm focus:bg-cyan-500 focus:px-4 focus:py-2 focus:text-white focus:font-semibold"
    >
      Skip to main content
    </a>
    <InteractiveLayer />
    <Nav />
    <main id="main-content">
      <slot />
    </main>
    <Footer />

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

      const navLinks = document.querySelectorAll<HTMLAnchorElement>('header nav a[href^="#"]');
      const sections = Array.from(navLinks)
        .map((link) => {
          const id = link.getAttribute('href')?.slice(1);
          const section = id ? document.getElementById(id) : null;
          return section ? { link, section } : null;
        })
        .filter((entry): entry is { link: HTMLAnchorElement; section: HTMLElement } => entry !== null);

      const highlightNav = () => {
        const offset = 120;
        let current = sections[0]?.link;

        sections.forEach(({ link, section }) => {
          if (section.getBoundingClientRect().top - offset <= 0) {
            current = link;
          }
        });

        navLinks.forEach((link) => {
          link.classList.toggle('nav-link-active', link === current);
        });
      };

      highlightNav();
      window.addEventListener('scroll', highlightNav, { passive: true });
    </script>
  </body>
</html>